# ===== (A) WHAT TO RUN ONCE IN YOUR REPO — vendoring CCCL as a submodule =====
# In your repo root:
#   Choose a stable v2.x tag (e.g., v2.4.x or v2.6.x). If unsure, pick a mid-2024 tag.
#   You can change the tag later without changing your source.
#
# git submodule add https://github.com/NVIDIA/cccl.git external/cccl
# git -C external/cccl checkout v2.4.0      # example stable tag
# git submodule update --init --recursive
# git commit -am "Vendor CCCL (CUB/Thrust/libcu++)"

# ===== (B) CMake changes (edit your CMakeLists.txt) =====
# TIP: there's a minor typo at the very top of your CMake (use 'cmake_minimum_required').
# File: CMakeLists.txt
cmake_minimum_required(VERSION 3.18)

if(NOT CMAKE_BUILD_TYPE)
  set(CMAKE_BUILD_TYPE Release)
endif()

set(CMAKE_CUDA_STANDARD 17)
project(index_prototype C CXX CUDA)

find_package(CUDAToolkit REQUIRED)
find_package(OpenMP REQUIRED)

mark_as_advanced(CUDA_SDK_ROOT_DIR)

include(cmake/configure_optix.cmake)
include(${CMAKE_CURRENT_SOURCE_DIR}/../ext/nvtx/nvtxImportedTargets.cmake)

# --- Add CCCL include dirs BEFORE CUDA's includes to ensure we pick vendored headers ---
set(CCCL_ROOT ${CMAKE_CURRENT_SOURCE_DIR}/external/cccl)
if(NOT EXISTS "${CCCL_ROOT}/cub" OR NOT EXISTS "${CCCL_ROOT}/thrust")
  message(FATAL_ERROR "CCCL not found at ${CCCL_ROOT}. Did you add the submodule?")
endif()

# SYSTEM + BEFORE: treat as system headers (avoid -Werror from third-party) and put first on include search path
target_include_directories(index_prototype SYSTEM BEFORE PRIVATE
  ${CCCL_ROOT}                     # contains 'cub/' and 'thrust/' at top-level
  ${CCCL_ROOT}/libcudacxx/include  # provides <cuda/std/...> if CUB needs it
)

