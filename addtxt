# ===== (C) Example usage wrapper for cub::DeviceMerge (put in a header you include from host code) =====
# File: include/device_merge_utils.cuh
# Minimal, header-only helper you can call from host (two-phase temp storage). 
# Keep as a tiny utility to avoid repeating boilerplate.
# Usage:
#   device_merge_keys(d_a, na, d_b, nb, d_out, /*stream=*/0);
#
#pragma once
#include <cuda_runtime.h>
#include <cub/device/device_merge.cuh>

namespace dm {

template <typename T, typename Compare = cub::Less<T>>
inline void device_merge_keys(const T* d_a, size_t na,
                              const T* d_b, size_t nb,
                              T* d_out,
                              cudaStream_t stream = 0,
                              Compare comp = Compare{}) {
  void* temp = nullptr;
  size_t temp_bytes = 0;
  cub::DeviceMerge::MergeKeys(nullptr, temp_bytes, d_a, na, d_b, nb, d_out, comp, stream);
  cudaError_t st = cudaMalloc(&temp, temp_bytes);
  if (st != cudaSuccess) throw std::runtime_error("cudaMalloc(temp) failed");
  st = cub::DeviceMerge::MergeKeys(temp, temp_bytes, d_a, na, d_b, nb, d_out, comp, stream);
  if (st != cudaSuccess) { cudaFree(temp); throw std::runtime_error("DeviceMerge::MergeKeys failed"); }
  cudaFree(temp);
}

} // namespace dm

